# .NET build artifacts
**/bin/
**/obj/

# Node / Next.js
**/node_modules/
**/.next/
**/dist/

# Frontend is not part of the API image build (root-context); its node_modules can
# contain broken symlinks that break the context tar for ACR builds.
src/web/

# Git
.git/
.gitignore

# Agent worktrees + session data — each worktree under .claude/ carries its own full source
# tree, so without this the root build context balloons by gigabytes (and uploads to ACR).
.claude/
.claire/

# IDE
.vs/
.vscode/
*.user

# Infra / CI / docs (not needed in image)
infra/
.github/
plans/

# Secrets
.monday_tkn

# Test outputs
**/TestResults/
